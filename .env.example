# ─── 농민일손 플랫폼 환경변수 ─────────────────────────────────────
# 이 파일을 .env 로 복사 후 값을 채우세요: copy .env.example .env

# ─── 서버 ─────────────────────────────────────────────────────────
PORT=3002
HOST=0.0.0.0
CORS_ORIGIN=*
USE_SEED_DATA=true
NODE_ENV=development

# ─── 카카오 알림톡 모드 ─────────────────────────────────────────────
#
# KAKAO_MODE=MOCK  → 콘솔 로그만 출력 (기본값, 개발용)
# KAKAO_MODE=REAL  → SolAPI 실발송 (운영용, 아래 값 모두 필요)
#
# 하위 호환: USE_KAKAO=true 도 REAL 모드로 동작
#
KAKAO_MODE=MOCK
USE_KAKAO=false

# ─── SolAPI 인증 (REAL 모드 필수) ────────────────────────────────────
# https://console.solapi.com → 계정 → API Key 관리
KAKAO_API_KEY=
KAKAO_API_SECRET=

# 카카오 비즈채널 발신 프로필 ID
# 카카오 비즈채널 등록 → SolAPI 콘솔 → 카카오 채널 → PfId 확인
KAKAO_PFID=

# 발신 번호 (사전 등록 필수, 숫자만: 01012345678)
KAKAO_FROM=

# ─── 알림톡 템플릿 코드 ───────────────────────────────────────────────
# SolAPI 콘솔 → 알림톡 → 템플릿 등록 후 코드 확인
KAKAO_TEMPLATE_CODE_JOB_MATCH=
KAKAO_TEMPLATE_CODE_SELECT=
KAKAO_TEMPLATE_CODE_START=
KAKAO_TEMPLATE_CODE_COMPLETE=

# ─── 서비스 도메인 (알림 링크용) ──────────────────────────────────────
SERVICE_DOMAIN=https://your-ngrok-url.ngrok-free.app

# ─── 테스트 모드 ──────────────────────────────────────────────────────
# KAKAO_TEST_MODE=true → 모든 알림을 KAKAO_TEST_PHONE 으로만 발송 (안전)
# KAKAO_TEST_MODE=false → 실제 사용자 번호로 발송
KAKAO_TEST_MODE=true
KAKAO_TEST_PHONE=821012345678

# ─── ngrok ────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=

# ─── Admin Dashboard ─────────────────────────────────────────────
ADMIN_KEY=your-secret-admin-key
