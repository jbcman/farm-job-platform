# ─── 농민일손 플랫폼 환경변수 ─────────────────────────────────────

# ─── 서버 ─────────────────────────────────────────────────────────
PORT=3002
HOST=0.0.0.0
CORS_ORIGIN=*
USE_SEED_DATA=true
NODE_ENV=development

# ─── VWorld 지도 API KEY ───────────────────────────────────────────
# 관제 시스템과 동일한 VWorld 키 (Phase 12.5 통일)
VITE_VWORLD_KEY=40875C91-3F61-31B1-869E-6AFE1364138B

# ─── 카카오 알림톡 모드 ─────────────────────────────────────────────
KAKAO_MODE=MOCK
USE_KAKAO=false

# ─── SolAPI 인증 (REAL 모드 필수) ────────────────────────────────────
KAKAO_API_KEY=
KAKAO_API_SECRET=
KAKAO_PFID=
KAKAO_FROM=

# ─── 알림톡 템플릿 코드 ───────────────────────────────────────────────
KAKAO_TEMPLATE_CODE_JOB_MATCH=
KAKAO_TEMPLATE_CODE_SELECT=
KAKAO_TEMPLATE_CODE_START=
KAKAO_TEMPLATE_CODE_COMPLETE=

# ─── 서비스 도메인 (알림 링크용) ──────────────────────────────────────
SERVICE_DOMAIN=https://your-ngrok-url.ngrok-free.app

# ─── 테스트 모드 ──────────────────────────────────────────────────────
KAKAO_TEST_MODE=true
KAKAO_TEST_PHONE=821012345678

# ─── ngrok ────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=

# ─── Admin Dashboard ─────────────────────────────────────────────
ADMIN_KEY=your-secret-admin-key

# ─── 토스페이먼츠 (PHASE SCALE+) ─────────────────────────────────
# 대시보드: https://developers.tosspayments.com/
# 테스트 키: test_sk_... / 운영 키: live_sk_...
TOSS_SECRET_KEY=
VITE_TOSS_CLIENT_KEY=

# ─── 농촌일손 운영자 정보 (FARMER_PAY_UX) ────────────────────────
# 결제 안내용 운영자 전화번호 및 계좌
VITE_OPERATOR_PHONE=01012345678
VITE_BANK_NAME=농협
VITE_BANK_ACCOUNT=302-0000-0000-00
VITE_BANK_HOLDER=농촌일손플랫폼
